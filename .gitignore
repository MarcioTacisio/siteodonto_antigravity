# .gitignore robusto para projetos Web (Estáticos / Node.js / IDEs)

# Dependency directories
node_modules/
jspm_packages/
web_modules/

# Build and temporary output directories
dist/
tmp/
out/
build/
.next/
.nuxt/
.cache/
.parcel-cache/
.serverless/
.server/
.env.local
.env.*.local

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Diagnostic reports (next.js / node)
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Optional npm cache directory
.npm

# Output of 'npm pack'
*.tgz

# Yarn Integrity file
.yarn-integrity

# dotenv environment variables file
.env
.env.development
.env.test
.env.production

# IDEs and Editors
.vscode/
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
*.swo

# Operating System Files
.DS_Store
Thumbs.db
desktop.ini

# Project local files
publish.bat
*.backup
