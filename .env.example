# Modelo de Configuração de Variáveis de Ambiente - OralCure Premium
# Renomeie este arquivo para '.env' para desenvolvimento local ou insira nas configurações de produção

# Porta de execução para servidores locais (se aplicável futuramente)
PORT=3000

# Exemplo de configurações para formulário de e-mail / API de Agendamento
API_AGENDAMENTO_URL=https://api.oralcurepremium.com/v1
API_AGENDAMENTO_KEY=sua_chave_de_api_aqui_nao_publique_a_real

# Exemplo de credenciais de serviços de mensageria (WhatsApp / Twilio se aplicável)
WHATSAPP_PHONE_NUMBER=5500999999999
TWILIO_ACCOUNT_SID=ACXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
TWILIO_AUTH_TOKEN=sua_chave_de_autenticacao_aqui

# Configurações de Banco de Dados (se houver migração para aplicação fullstack)
DB_HOST=localhost
DB_USER=root
DB_PASS=sua_senha_secreta
DB_NAME=oralcure_db
